{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@luolapeikko/odata-query-filter",
  "version": "0.0.3",
  "description": "OData $filter string parser and evaluator",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "default": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --minify --sourcemap --format cjs,esm --dts --clean",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check",
    "test": "vitest test --typecheck --run --no-isolate --coverage",
    "coverage": "vitest test --run --no-isolate --reporter=dot --coverage --coverage.reporter=lcov",
    "validate": "tsc --noEmit --project tsconfig.test.json"
  },
  "keywords": [
    "odata",
    "query",
    "filter"
  ],
  "author": "mharj",
  "repository": "github:luolapeikko/odata-query-filter",
  "homepage": "https://github.com/luolapeikko/odata-query-filter#readme",
  "bugs": {
    "url": "https://github.com/luolapeikko/odata-query-filter/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@vitest/coverage-v8": "^4.1.1",
    "c8": "^11.0.0",
    "tsdown": "^0.21.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
